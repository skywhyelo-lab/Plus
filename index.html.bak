                <div class="mock-section-desc">Мониторинг ресурсов вашего компьютера в реальном времени</div>
                
                <div class="dash-widgets">
                  <div class="gauge-widget">
                    <div class="gauge-circle">
                      <svg width="60" height="60" viewBox="0 0 60 60">
                        <circle cx="30" cy="30" r="26" fill="none" stroke="rgba(255,255,255,.03)" stroke-width="4.5"/>
                        <circle id="dashGaugeArc" cx="30" cy="30" r="26" fill="none" stroke="var(--green)" stroke-width="4.5" stroke-linecap="round" stroke-dasharray="163.3" stroke-dashoffset="65"/>
                      </svg>
                      <div class="gauge-val" id="dashGaugeVal">60%</div>
                    </div>
                    <span class="gauge-label" id="dashGaugeState">В норме</span>
                  </div>
                  
                  <div class="dash-telemetry">
                    <div class="dt-card"><div class="k">CPU Load</div><div class="v" id="telCpu">12%</div></div>
                    <div class="dt-card"><div class="k">RAM Used</div><div class="v" id="telRam">5.4 GB</div></div>
                    <div class="dt-card"><div class="k">Disk Active</div><div class="v" id="telDisk">1%</div></div>
                  </div>
