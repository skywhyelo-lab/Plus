  <!-- ============ JAVASCRIPT ============ -->
  <script>
    const reducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    const isMobileDevice = /Android|webOS|iPhone|iPad|iPod|BlackBerry|IEMobile|Opera Mini/i.test(navigator.userAgent) || window.innerWidth < 640;
    
    // Add is-mobile class to body dynamically if mobile
    if (isMobileDevice) {
      document.body.classList.add('is-mobile');
    }

    /* ---------- BRAND ACCENT (blue, mirrors the app chrome) — read by the hero canvas ---------- */
    window.pulseAccentRGB = '59, 130, 246';

    /* ---------- HERO: entrance choreography + 3D mouse-tilt + magnetic CTAs ---------- */
    (function() {
      // Trigger the staggered entrance once the DOM is ready
      const hero = document.querySelector('.hero');
      requestAnimationFrame(() => document.body.classList.add('hero-loaded'));

      const canHover = window.matchMedia('(hover: hover)').matches;
      const stage = document.querySelector('.hero-stage');
      const win = document.getElementById('heroWindow');
      const floats = document.querySelectorAll('[data-tilt-float]');

      // 3D tilt of the app window following the pointer (desktop only, respects reduced-motion)
      if (hero && stage && win && canHover && !reducedMotion) {
        let tx = 0, ty = 0, raf = null;
        const apply = () => {
          win.style.transform = `rotateY(${tx}deg) rotateX(${ty}deg)`;
          floats.forEach((f, i) => {
            const depth = (i + 1) * 6;
            f.style.transform = `translate3d(${tx * depth * 0.4}px, ${ty * -depth * 0.4}px, 0)`;
          });
          raf = null;
        };
        hero.addEventListener('pointermove', (e) => {
          const r = hero.getBoundingClientRect();
          const px = (e.clientX - r.left) / r.width - 0.5;
          const py = (e.clientY - r.top) / r.height - 0.5;
          tx = px * 10;
          ty = -py * 7;
          if (!raf) raf = requestAnimationFrame(apply);
        }, { passive: true });
        hero.addEventListener('pointerleave', () => {
          tx = 0; ty = 0;
          if (!raf) raf = requestAnimationFrame(apply);
        });
      }

      // Magnetic pull on primary CTAs
      if (canHover && !reducedMotion) {
        document.querySelectorAll('.magnetic').forEach(btn => {
          btn.addEventListener('pointermove', (e) => {
            const r = btn.getBoundingClientRect();
            const mx = (e.clientX - r.left - r.width / 2) * 0.25;
            const my = (e.clientY - r.top - r.height / 2) * 0.35;
            btn.style.transform = `translate(${mx}px, ${my}px)`;
          });
          btn.addEventListener('pointerleave', () => { btn.style.transform = ''; });
        });
      }

      // Profile switcher — retints the hero (glow, canvas, app-window) like the real app
      const profileRGB = { standard: '59, 130, 246', gaming: '139, 92, 246', maximum: '239, 68, 68' };
      const profileIdx = { standard: 0, gaming: 1, maximum: 2 };
      const pills = document.querySelectorAll('.profile-pill');
      const awProfileIcons = document.querySelectorAll('.aw-profiles .awp');
      pills.forEach(pill => {
        pill.addEventListener('click', () => {
          const p = pill.dataset.profile;
          document.documentElement.setAttribute('data-profile', p);
          window.pulseAccentRGB = profileRGB[p] || profileRGB.standard;
          pills.forEach(x => { x.classList.remove('active'); x.removeAttribute('aria-selected'); });
          pill.classList.add('active');
          pill.setAttribute('aria-selected', 'true');
          // Mirror the selection on the app-window's top toggle
          awProfileIcons.forEach((ic, i) => ic.classList.toggle('active', i === profileIdx[p]));
        });
      });
    })();

    /* ---------- HERO CANVAS BACKGROUND (SUBTLE ECG WAVE + PARTICLES) ---------- */
    (function() {
      const canvas = document.getElementById('heroCanvas');
      if (!canvas) return;
      const ctx = canvas.getContext('2d');
      const dpr = Math.min(window.devicePixelRatio || 1, 2);
      let width, height;

      // 1. Declare and initialize data arrays first (avoids TDZ reference errors on initial resize)
      const particles = [];
      const particleCount = isMobileDevice ? 15 : 65; 
      for (let i = 0; i < particleCount; i++) {
        particles.push({
          x: Math.random(),
          y: Math.random(),
          r: Math.random() * 1.6 + 0.5, 
          speedY: Math.random() * 0.0003 + 0.0001,
          alpha: Math.random() * 0.32 + 0.06 
        });
      }

      // Track mouse position
      let mouse = { x: -1000, y: -1000, active: false };
      if (!isMobileDevice) {
        window.addEventListener('mousemove', (e) => {
          const rect = canvas.getBoundingClientRect();
          mouse.x = (e.clientX - rect.left) * dpr;
          mouse.y = (e.clientY - rect.top) * dpr;
          mouse.active = true;
        });
        window.addEventListener('mouseleave', () => {
          mouse.active = false;
        });
      }

      // Latency wave coordinates
      const wavePoints = [];
      let beatCountdown = 0;
      const beatPattern = [0, -3, 10, -25, 8, -2, 0];
      
      function getNextWaveHeight() {
        if (beatCountdown > 0) {
          const val = beatPattern[beatPattern.length - beatCountdown];
          beatCountdown--;
          return val;
        }
        if (Math.random() < 0.012) {
          beatCountdown = beatPattern.length - 1;
        }
        return (Math.random() - 0.5) * 1.5;
      }

      // 2. Define sizing functions
      function resize() {
        const rect = canvas.getBoundingClientRect();
        width = canvas.width = (rect.width || canvas.offsetWidth) * dpr;
        height = canvas.height = (rect.height || canvas.offsetHeight) * dpr;
        if (reducedMotion && width > 0 && height > 0) {
          draw(); 
        }
      }

      // 3. Define rendering loop
      function draw() {
        if (!width || !height) {
          resize();
          if (!width || !height) {
            if (!reducedMotion) requestAnimationFrame(draw);
            return;
          }
        }
        ctx.clearRect(0, 0, width, height);

        // Ambient cursor glow trail under particles
        if (mouse.active && !reducedMotion) {
          const AC = window.pulseAccentRGB || '139, 92, 246';
          const rad = ctx.createRadialGradient(mouse.x, mouse.y, 0, mouse.x, mouse.y, 110 * dpr);
          rad.addColorStop(0, 'rgba(' + AC + ', 0.08)');
          rad.addColorStop(1, 'rgba(' + AC + ', 0)');
          ctx.fillStyle = rad;
          ctx.beginPath();
          ctx.arc(mouse.x, mouse.y, 110 * dpr, 0, Math.PI * 2);
          ctx.fill();
        }

        // Draw particles
        for (const p of particles) {
          p.y -= p.speedY;
          if (p.y < -0.01) {
            p.y = 1.01;
            p.x = Math.random();
          }
          
          let px = p.x * width;
          let py = p.y * height;

          // Gentle mouse repulsion force
          if (mouse.active && !reducedMotion) {
            const dx = px - mouse.x;
            const dy = py - mouse.y;
            const dist = Math.hypot(dx, dy);
            if (dist < 90 * dpr) {
              const force = (90 * dpr - dist) / (90 * dpr);
              p.x += (dx / dist) * force * 0.006;
              p.x = Math.max(0.001, Math.min(0.999, p.x));
            }
          }

          ctx.globalAlpha = p.alpha;
          ctx.fillStyle = 'rgb(' + (window.pulseAccentRGB || '139, 92, 246') + ')';
          ctx.beginPath();
          ctx.arc(p.x * width, p.y * height, p.r * dpr, 0, Math.PI * 2);
          ctx.fill();
        }

        // Draw dynamic constellation connection lines between close particles
        if (!reducedMotion) {
          ctx.strokeStyle = 'rgba(' + (window.pulseAccentRGB || '139, 92, 246') + ', 0.18)';
          ctx.lineWidth = 0.75 * dpr;
          for (let i = 0; i < particles.length; i++) {
            for (let j = i + 1; j < particles.length; j++) {
              const dx = (particles[i].x - particles[j].x) * width;
              const dy = (particles[i].y - particles[j].y) * height;
              const dist = Math.hypot(dx, dy);
              if (dist < 105 * dpr) { 
                ctx.globalAlpha = (1 - dist / (105 * dpr)) * 0.22;
                ctx.beginPath();
                ctx.moveTo(particles[i].x * width, particles[i].y * height);
                ctx.lineTo(particles[j].x * width, particles[j].y * height);
                ctx.stroke();
              }
            }
          }
        }

        // Draw subtle latency wave (ECG)
        ctx.globalAlpha = 1;
        const step = 4 * dpr;
        const maxPoints = Math.ceil(width / step) + 2;

        wavePoints.push(getNextWaveHeight());
        while (wavePoints.length > maxPoints) {
          wavePoints.shift();
        }

        const baseline = height * 0.55;
        ctx.strokeStyle = 'rgba(' + (window.pulseAccentRGB || '139, 92, 246') + ', 0.16)';
        ctx.lineWidth = 1.5 * dpr;
        ctx.lineJoin = 'round';
        ctx.lineCap = 'round';
        ctx.beginPath();

        for (let i = 0; i < wavePoints.length; i++) {
          const x = i * step;
          const y = baseline + wavePoints[i] * dpr * 1.8;
          if (i === 0) ctx.moveTo(x, y);
          else ctx.lineTo(x, y);
        }
        ctx.stroke();

        if (!reducedMotion) requestAnimationFrame(draw);
      }

      // 4. Initialize size, bind events, and start rendering loop only after full scope setup
      resize();
      window.addEventListener('resize', resize);
      window.addEventListener('load', resize); 
      draw();
    })();

    /* ---------- RESULTS PROGRESS BARS ANIMATION ---------- */
    const resultsObserver = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          document.querySelectorAll('.chart-bar-fill').forEach(fill => {
            fill.style.width = fill.dataset.w;
          });
          resultsObserver.disconnect();
        }
      });
    }, { threshold: 0.2 });

    const barsBlock = document.getElementById('barsBlock');
    if (barsBlock) resultsObserver.observe(barsBlock);


    /* =========================================================
       MOCKUP CONTROLLER (INTERACTIVE WINDOW)
       ========================================================= */
    const mockupState = {
      activeTab: 'dash',
      freedRamTotal: 0,
      customExceptions: ['cs2.exe', 'Discord.exe'],
      systemExceptions: ['dwm.exe', 'explorer.exe', 'svchost.exe', 'csrss.exe'],
      
      // Processes initially available for termination
      processes: [
        { name: 'chrome.exe', pid: 9992, ram: 452, color: '#ef4444', terminable: true },
        { name: 'chrome.exe', pid: 8744, ram: 371, color: '#ef4444', terminable: true },
        { name: 'Spotify.exe', pid: 5104, ram: 188, color: '#10b981', terminable: true },
        { name: 'steamwebhelper.exe', pid: 7212, ram: 389, color: '#3b82f6', terminable: true },
        { name: 'Discord.exe', pid: 6604, ram: 512, color: '#6366f1', terminable: true },
        { name: 'nvcontainer.exe', pid: 4320, ram: 42, color: '#10b981', terminable: false, badge: 'Protected' },
        { name: 'cs2.exe', pid: 14201, ram: 1834, color: '#f59e0b', terminable: false, badge: 'Game' },
        { name: 'explorer.exe', pid: 2110, ram: 85, color: '#64748b', terminable: false, badge: 'System' }
      ],

      // Optimization status
      optRunning: false,
      optProgress: 0,
      optSteps: [
        { text: 'Инициализация оптимизации...', w: 10, type: 'info' },
        { text: 'Создание точки восстановления реестра... ОК', w: 25, type: 'success' },
        { text: 'Отключение фоновой телеметрии (DiagTrack)... ОК', w: 45, type: 'success' },
        { text: 'Настройка сетевых задержек (TCP Nodelay)... ОК', w: 65, type: 'success' },
        { text: 'Очистка системного кэша файловой системы... ОК', w: 80, type: 'success' },
        { text: 'Сжатие страниц неактивного ОЗУ... ОК', w: 95, type: 'success' },
        { text: 'Pulse: Оптимизация системы завершена успешно! [191 твик]', w: 100, type: 'done' }
      ]
    };

    // DOM Elements
    const mockupMenuElements = document.querySelectorAll('.mock-menu-item');
    const mockupPanels = document.querySelectorAll('.mock-panel');
    const procTableBody = document.getElementById('procTableBody');
    const procSearch = document.getElementById('procSearch');
    const sysExcList = document.getElementById('sysExcList');
    const userExcList = document.getElementById('userExcList');
    const excInput = document.getElementById('excInput');
    const excAddBtn = document.getElementById('excAddBtn');
    const userExcCount = document.getElementById('userExcCount');
    const sysExcCount = document.getElementById('sysExcCount');
    
    const telCpu = document.getElementById('telCpu');
    const telRam = document.getElementById('telRam');
    const telDisk = document.getElementById('telDisk');
    const telLatency = document.getElementById('telLatency');
    const telFreed = document.getElementById('telFreed');
    const dashGaugeArc = document.getElementById('dashGaugeArc');
    const dashGaugeVal = document.getElementById('dashGaugeVal');
    const dashGaugeState = document.getElementById('dashGaugeState');

    const optStartBtn = document.getElementById('optStartBtn');
    const optProgressBar = document.getElementById('optProgressBar');
    const optTerminal = document.getElementById('optTerminal');
    const optStateLabel = document.getElementById('optStateLabel');
    const optStateSub = document.getElementById('optStateSub');
    const procTotalTerminable = document.getElementById('procTotalTerminable');
    const procFreedStatus = document.getElementById('procFreedStatus');

    /* --- Tab Switcher --- */
    mockupMenuElements.forEach(item => {
      item.addEventListener('click', () => {
        const target = item.dataset.target;
        
        // Update Sidebar UI
        mockupMenuElements.forEach(i => i.classList.remove('active'));
        item.classList.add('active');

        // Update Panel Visibility
        mockupPanels.forEach(p => p.classList.remove('active'));
        const activePanel = document.getElementById(`panel-${target}`);
        if (activePanel) activePanel.classList.add('active');

        mockupState.activeTab = target;
      });
    });

    /* --- Dashboard Timeline Loop --- */
    const N = 40;
    const chartCpuData = Array.from({length: N}, () => 10 + Math.random() * 8);
    const chartRamData = Array.from({length: N}, () => 40 + Math.random() * 2);
    
    function updateChart() {
      // 1. Generate new values
      let cpuVal = 8 + Math.random() * 6;
      let ramVal = 38 + Math.random() * 2;
      
      // Spikes
      if (Math.random() < 0.05) cpuVal += 20 + Math.random() * 15;

      chartCpuData.push(cpuVal);
      chartCpuData.shift();
      chartRamData.push(ramVal);
      chartRamData.shift();

      // 2. Render CPU & RAM paths
      const step = 400 / (N - 1);
      
      let dCpu = `M 0,${120 - chartCpuData[0] * 1.1}`;
      let dRam = `M 0,${120 - chartRamData[0] * 1.1}`;
      
      for (let i = 1; i < N; i++) {
        dCpu += ` L ${i * step},${120 - chartCpuData[i] * 1.1}`;
        dRam += ` L ${i * step},${120 - chartRamData[i] * 1.1}`;
      }

      const pathCpu = document.getElementById('pathChartCpu');
      const pathRam = document.getElementById('pathChartRam');
      
      if (pathCpu) pathCpu.setAttribute('d', dCpu);
      if (pathRam) pathRam.setAttribute('d', dRam);

      // 3. Update Dashboard Stats text
      const currentCpu = Math.round(chartCpuData[N-1]);
      const currentRam = (8.2 * (chartRamData[N-1] / 100)).toFixed(1);
      
      if (telCpu) telCpu.textContent = `${currentCpu}%`;
      if (telRam) telRam.textContent = `${currentRam} GB`;
      if (telDisk) telDisk.textContent = `${Math.random() < 0.2 ? Math.round(Math.random() * 3) : 0}%`;

      // 4. Update Gauge
      const totalSystemLoad = Math.min(100, Math.round(currentCpu + 25));
      if (dashGaugeVal) dashGaugeVal.textContent = `${totalSystemLoad}%`;
      if (dashGaugeArc) {
        const C = 163.3; // 2 * PI * r (r=26)
        dashGaugeArc.style.strokeDashoffset = C - (C * totalSystemLoad) / 100;
      }
    }

    if (!reducedMotion) {
      setInterval(updateChart, 1000);
    }
    updateChart();

    /* --- Processes Manager Operations --- */
    function renderProcesses() {
      if (!procTableBody) return;
      
      const searchVal = procSearch.value.trim().toLowerCase();
      const filtered = mockupState.processes.filter(p => p.name.toLowerCase().includes(searchVal));

      if (filtered.length === 0) {
        procTableBody.innerHTML = `<tr><td colspan="4" style="text-align:center;color:var(--text-dark);padding:24px;">Задачи не найдены</td></tr>`;
        return;
      }

      procTableBody.innerHTML = filtered.map((p, idx) => {
        // Check if the process name is in the user exceptions list
        const isCustomExcluded = mockupState.customExceptions.includes(p.name);
        const isSystemExcluded = mockupState.systemExceptions.includes(p.name);
        
        let actionsHtml = '';
        if (isSystemExcluded || isCustomExcluded) {
          actionsHtml = `<span class="proc-status-shield">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
            Защищён
          </span>`;
        } else {
          actionsHtml = `
            <div class="proc-actions">
              <button class="proc-btn-action btn-list" onclick="addProcessToExceptions('${p.name}')">В список</button>
              <button class="proc-btn-action btn-kill" onclick="killProcess(${p.pid})">Закрыть</button>
            </div>
          `;
        }

        return `
          <tr class="proc-tr" id="proc-pid-${p.pid}">
            <td>
              <div class="proc-name-cell">
                <span class="proc-icon" style="background:${p.color}15;color:${p.color};border:1px solid ${p.color}35">
                  ${p.name[0].toUpperCase()}
                </span>
                ${p.name}
              </div>
            </td>
            <td style="font-family:var(--font-mono);color:var(--text-dark)">${p.pid}</td>
            <td style="font-family:var(--font-mono);font-weight:600">${p.ram} МБ</td>
            <td style="text-align:right">${actionsHtml}</td>
          </tr>
        `;
      }).join('');

      // Calculate totals
      let totalTerminable = 0;
      mockupState.processes.forEach(p => {
        const isExcluded = mockupState.customExceptions.includes(p.name) || mockupState.systemExceptions.includes(p.name);
        if (!isExcluded && p.terminable) {
          totalTerminable += p.ram;
        }
      });

      if (procTotalTerminable) {
        procTotalTerminable.textContent = `${totalTerminable} МБ`;
      }
    }

    if (procSearch) {
      procSearch.addEventListener('input', renderProcesses);
    }

    function triggerPulse(element) {
      if (!element) return;
      element.classList.remove('pulse-effect');
      void element.offsetWidth; // trigger reflow
      element.classList.add('pulse-effect');
      setTimeout(() => element.classList.remove('pulse-effect'), 400);
    }

    window.killProcess = function(pid) {
      const idx = mockupState.processes.findIndex(p => p.pid === pid);
      if (idx === -1) return;

      const p = mockupState.processes[idx];
      const row = document.getElementById(`proc-pid-${pid}`);
      if (row) {
        row.style.background = 'rgba(239, 68, 68, 0.08)';
        row.style.opacity = '0';
        row.style.transform = 'translateX(20px)';
        row.style.transition = 'all 0.4s ease';
        
        setTimeout(() => {
          // Free resources
          mockupState.freedRamTotal += p.ram;
          if (telFreed) {
            telFreed.textContent = `${mockupState.freedRamTotal} МБ`;
            triggerPulse(telFreed);
          }
          if (procFreedStatus) procFreedStatus.textContent = `Всего закрыто: ${mockupState.freedRamTotal} МБ`;
          
          // Remove from list
          mockupState.processes.splice(idx, 1);
          
          // Update latency telemetry if RAM is freed (simulating system cleanup)
          const newLatency = Math.max(38, 42 - Math.round(mockupState.freedRamTotal / 120));
          if (telLatency) {
            telLatency.textContent = `${newLatency} мкс`;
            triggerPulse(telLatency);
          }

          renderProcesses();
        }, 400);
      }
    };

    window.addProcessToExceptions = function(name) {
      if (!mockupState.customExceptions.includes(name)) {
        mockupState.customExceptions.push(name);
        renderProcesses();
        renderExceptions();
      }
    };

    /* --- Exceptions Manager --- */
    function renderExceptions() {
      if (!sysExcList || !userExcList) return;

      // Sys List (Read-only)
      sysExcList.innerHTML = mockupState.systemExceptions.map(name => `
        <div class="exc-item">
          <span class="exc-item-name">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><rect x="4" y="11" width="16" height="10" rx="2"/><path d="M8 11V7a4 4 0 0 1 8 0v4"/></svg>
            ${name}
          </span>
        </div>
      `).join('');
      sysExcCount.textContent = mockupState.systemExceptions.length;

      // User List
      userExcList.innerHTML = mockupState.customExceptions.map(name => `
        <div class="exc-item">
          <span class="exc-item-name">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="m12 2 3.1 6.3 6.9 1-5 4.9 1.2 6.8L12 17.8 5.8 21l1.2-6.8-5-4.9 6.9-1z"/></svg>
            ${name}
          </span>
          <span class="exc-remove-btn" onclick="removeException('${name}')">Убрать</span>
        </div>
      `).join('');
      userExcCount.textContent = mockupState.customExceptions.length;
    }

    window.removeException = function(name) {
      const idx = mockupState.customExceptions.indexOf(name);
      if (idx !== -1) {
        mockupState.customExceptions.splice(idx, 1);
        renderExceptions();
        renderProcesses();
      }
    };

    if (excAddBtn && excInput) {
      excAddBtn.addEventListener('click', () => {
        const val = excInput.value.trim().toLowerCase();
        if (val && !val.includes(' ') && val.endsWith('.exe')) {
          if (!mockupState.customExceptions.includes(val) && !mockupState.systemExceptions.includes(val)) {
            mockupState.customExceptions.push(val);
            excInput.value = '';
            renderExceptions();
            renderProcesses();
          }
        } else {
          alert('Введите имя исполняемого файла с расширением .exe (например, game.exe)');
        }
      });
    }

    // Initial render
    renderProcesses();
    renderExceptions();

    /* --- Optimization Simulation Logic --- */
    if (optStartBtn) {
      optStartBtn.addEventListener('click', () => {
        if (mockupState.optRunning) return;
        
        mockupState.optRunning = true;
        optStartBtn.classList.add('running');
        optStateLabel.textContent = 'Оптимизация...';
        optStateSub.textContent = 'Внесение изменений в реестр Windows';

        optTerminal.innerHTML = '<div class="opt-terminal-line blue">&gt; Запуск оптимизации Pulse...</div>';
        optProgressBar.style.width = '0%';
        
        let stepIdx = 0;
        function runStep() {
          if (stepIdx < mockupState.optSteps.length) {
            const step = mockupState.optSteps[stepIdx];
            
            // Add terminal log line
            const line = document.createElement('div');
            line.className = 'opt-terminal-line';
            if (step.type === 'success') line.classList.add('green');
            if (step.type === 'done') line.classList.add('blue');
            line.innerHTML = `[${stepIdx + 1}/7] ${step.text}`;
            optTerminal.appendChild(line);
            optTerminal.scrollTop = optTerminal.scrollHeight;

            // Progress bar
            optProgressBar.style.width = `${step.w}%`;
            
            stepIdx++;
            setTimeout(runStep, 800 + Math.random() * 600);
          } else {
            // Done
            mockupState.optRunning = false;
            optStartBtn.classList.remove('running');
            optStateLabel.textContent = 'Готово';
            optStateSub.textContent = 'Система полностью оптимизирована';
            
            // Trigger animation on landing page FPS metrics to show before/after
            document.querySelectorAll('.chart-bar-fill').forEach(fill => {
              fill.style.width = fill.dataset.w;
            });

            // Change telemetry values in mockup
            if (telLatency) {
              telLatency.textContent = '38 мкс';
              triggerPulse(telLatency);
            }
          }
        }

        setTimeout(runStep, 400);
      });
    }

    /* ---------- GITHUB RELEASE CHECKER (last update date for Pulse.exe) ---------- */
    async function checkPulseUpdates() {
      try {
        const res = await fetch('https://api.github.com/repos/skywhyelo-lab/Plus/releases/latest');
        if (!res.ok) return;
        const release = await res.json();
        const asset = release.assets && release.assets.find(a => a.name === 'Pulse.exe');
        if (!asset || !asset.updated_at) return;

        const d = new Date(asset.updated_at);
        const day = String(d.getDate()).padStart(2, '0');
        const month = String(d.getMonth() + 1).padStart(2, '0');
        const year = d.getFullYear();
        const formatted = `${day}.${month}.${year}`;
        const version = (release.tag_name || '').replace(/^v/i, '');

        const heroNote = document.getElementById('heroNote');
        if (heroNote) {
          const versionText = version ? `Версия ${version} · ` : '';
          heroNote.innerHTML = `${versionText}Windows 10 / 11 · Платная лицензия · Обновлено <span style="color:var(--accent); font-weight:600;">${formatted}</span>`;
        }

        const updatedRow = document.getElementById('lastUpdateRow');
        const specsUpdated = document.getElementById('specsUpdated');
        if (updatedRow && specsUpdated) {
          specsUpdated.textContent = formatted;
          updatedRow.style.display = '';
        }

        if (asset.size) {
          const sizeMB = (asset.size / (1024 * 1024)).toFixed(1);
          const specsSize = document.getElementById('specsSize');
          if (specsSize) specsSize.textContent = `${sizeMB} МБ`;
          const bandCountFile = document.querySelector('.band-card .count[data-target="99.3"]');
          if (bandCountFile) {
            bandCountFile.dataset.target = sizeMB;
            if (bandCountFile.textContent !== '0') bandCountFile.textContent = sizeMB;
          }
        }
      } catch (e) {
        console.error('Ошибка при получении обновлений с GitHub:', e);
      }
    }
    window.addEventListener('DOMContentLoaded', checkPulseUpdates);

    /* ---------- SPOTLIGHT HOVER EFFECT ---------- */
    if (!isMobileDevice) {
      document.querySelectorAll('.feat-card, .safe-card, .rev-card').forEach(card => {
        card.addEventListener('mousemove', (e) => {
          const rect = card.getBoundingClientRect();
          const x = e.clientX - rect.left;
          const y = e.clientY - rect.top;
          card.style.setProperty('--mouse-x', `${x}px`);
          card.style.setProperty('--mouse-y', `${y}px`);
        });
      });
    }

    /* ---------- REVEAL ON SCROLL ---------- */
    const revealObserver = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          entry.target.classList.add('reveal-active');
          revealObserver.unobserve(entry.target);
        }
      });
    }, { threshold: 0.08 });

    document.querySelectorAll('.reveal').forEach(el => {
      revealObserver.observe(el);
    });

    /* ---------- DYNAMIC NUMBER COUNTERS ON SCROLL ---------- */
    const countersObserver = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          const counter = entry.target;
          const target = parseFloat(counter.dataset.target);
          const decimals = parseInt(counter.dataset.decimals || '0');
          const duration = 1200; // ms
          const startTime = performance.now();

          function update(currentTime) {
            const progress = Math.min((currentTime - startTime) / duration, 1);
            // Ease out quad
            const easeProgress = progress * (2 - progress);
            const value = easeProgress * target;
            
            counter.textContent = value.toFixed(decimals);

            if (progress < 1) {
              requestAnimationFrame(update);
            } else {
              counter.textContent = target.toFixed(decimals);
            }
          }
          requestAnimationFrame(update);
          countersObserver.unobserve(counter);
        }
      });
    }, { threshold: 0.1 });

    document.querySelectorAll('.band-card .count').forEach(counter => {
      countersObserver.observe(counter);
    });

    /* ---------- BUY BUTTONS (Paddle card checkout + CryptoCloud/Trybit) ---------- */
    (function() {
      const buyCardBtn = document.getElementById('buyCardBtn');
      const buyCryptoBtn = document.getElementById('buyCryptoBtn');
      const buyError = document.getElementById('buyError');
      if (!buyCardBtn && !buyCryptoBtn) return;

      const PADDLE_CLIENT_TOKEN = 'live_aec6742e15aae2bef4c8e482107';
      const PADDLE_PRICE_ID = 'pri_01kxswmzkn326by5m08x7dxayk';
      if (window.Paddle) {
        window.Paddle.Setup({ token: PADDLE_CLIENT_TOKEN });
      }

      function showError(msg) {
        buyError.textContent = msg;
        buyError.style.display = 'block';
      }

      if (buyCardBtn) {
        buyCardBtn.addEventListener('click', async () => {
          buyCardBtn.disabled = true;
          const originalHtml = buyCardBtn.innerHTML;
          buyCardBtn.textContent = 'Открываем оплату…';
          buyError.style.display = 'none';

          try {
            const res = await fetch('/api/create-order', { method: 'POST' });
            const data = await res.json();
            if (!res.ok || !data.order_id) throw new Error(data.error || 'unknown error');

            localStorage.setItem('pulse_order_id', data.order_id);
            window.Paddle.Checkout.open({
              items: [{ priceId: PADDLE_PRICE_ID, quantity: 1 }],
              customData: { order_id: data.order_id },
              settings: { successUrl: `${location.origin}/success.html?order_id=${data.order_id}` },
            });
          } catch (err) {
            showError('Не удалось начать оплату картой. Попробуйте ещё раз или напишите в Telegram.');
          } finally {
            buyCardBtn.disabled = false;
            buyCardBtn.innerHTML = originalHtml;
          }
        });
      }

      if (buyCryptoBtn) {
        buyCryptoBtn.addEventListener('click', async () => {
          buyCryptoBtn.disabled = true;
          const originalHtml = buyCryptoBtn.innerHTML;
          buyCryptoBtn.textContent = 'Создаём счёт…';
          buyError.style.display = 'none';

          try {
            const res = await fetch('/api/create-invoice', { method: 'POST' });
            const data = await res.json();
            if (!res.ok || !data.pay_url) throw new Error(data.error || 'unknown error');

            localStorage.setItem('pulse_order_id', data.order_id);
            window.location.href = data.pay_url;
          } catch (err) {
            buyCryptoBtn.disabled = false;
            buyCryptoBtn.innerHTML = originalHtml;
            showError('Не удалось начать оплату криптой. Попробуйте ещё раз или напишите в Telegram.');
          }
        });
      }
    })();

  </script>

  <!-- ============ Хаос → Порядок — scroll scrub ============ -->
  <script>
  (function(){
    var wrap  = document.querySelector('.co-wrap');
    var stage = document.querySelector('.co-stage');
    if(!wrap || !stage) return;

    var rm = matchMedia('(prefers-reduced-motion: reduce)').matches;
    var isMobile = matchMedia('(max-width:760px)').matches;
    var counters = [].slice.call(stage.querySelectorAll('[data-co-count]'));
    var scopeVal = stage.querySelector('.co-scope-val');

    function clamp(v,a,b){ return v<a?a:(v>b?b:v); }
    function fmt(n){ return Math.round(n).toLocaleString('ru-RU'); }

    if(rm){
      counters.forEach(function(el){ el.textContent = fmt(+el.dataset.to) + (el.dataset.suffix||''); });
      if(scopeVal) scopeVal.textContent = '38 мкс';
      return;
    }

    if(isMobile){
      stage.classList.add('co-static');
      var io = new IntersectionObserver(function(ents){
        ents.forEach(function(e){
          if(e.isIntersecting){
            stage.style.setProperty('--p','1');
            counters.forEach(function(el){ el.textContent = fmt(+el.dataset.to) + (el.dataset.suffix||''); });
            if(scopeVal) scopeVal.textContent = '38 мкс';
            io.disconnect();
          }
        });
      }, {threshold:.35});
      io.observe(stage);
      return;
    }

    stage.style.setProperty('--p','0');
    var ticking = false, lastP = -1;

    function update(){
      ticking = false;
      var rect = wrap.getBoundingClientRect();
      var range = rect.height - stage.offsetHeight;
      var p = clamp(-rect.top / (range || 1), 0, 1);
      if(p === lastP) return;
      lastP = p;
      stage.style.setProperty('--p', p);
      var cp = clamp((p - 0.30) / 0.48, 0, 1);
      counters.forEach(function(el){
        var from = +el.dataset.from, to = +el.dataset.to, suf = el.dataset.suffix || '';
        el.textContent = fmt(from + (to - from) * cp) + suf;
      });
      if(scopeVal) scopeVal.textContent = fmt(150 + (38 - 150) * cp) + ' мкс';
    }

    function onScroll(){ if(!ticking){ ticking = true; requestAnimationFrame(update); } }
    addEventListener('scroll', onScroll, {passive:true});
    addEventListener('resize', function(){ lastP = -1; onScroll(); }, {passive:true});
    update();
  })();
  </script>
</body>
</html>
