                  <div class="opt-progress-track">
                    <div class="opt-progress-bar" id="optProgressBar"></div>
                  </div>

                  <div class="opt-terminal" id="optTerminal">
                    <div class="opt-terminal-line">Pulse готов к оптимизации Windows.</div>
                    <div class="opt-terminal-line" style="color:var(--text-dark)">Нажмите на ракету выше для старта.</div>
