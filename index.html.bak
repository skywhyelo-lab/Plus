  <!-- ============ RESULTS SECTION ============ -->
  <section class="results" id="results">
    <div class="wrap results-in">
      <div class="results-chart reveal" id="barsBlock">
        <div class="chart-bar-row">
          <div class="chart-bar-head">
            <span class="chart-bar-name">Средний FPS в CS2 (Без Pulse)</span>
            <span class="chart-bar-val">312 <span class="unit">FPS</span></span>
          </div>
          <div class="chart-bar-track">
            <div class="chart-bar-fill before" data-w="55%"></div>
          </div>
        </div>

        <div class="chart-bar-row">
          <div class="chart-bar-head">
            <span class="chart-bar-name">Средний FPS в CS2 (С примененным Pulse)</span>
            <span class="chart-bar-val" style="color:var(--accent)">450 <span class="unit" style="color:var(--accent)">FPS</span></span>
          </div>
          <div class="chart-bar-track">
            <div class="chart-bar-fill after" data-w="80%"></div>
          </div>
        </div>

        <div class="chart-bar-row" style="margin-top: 36px;">
          <div class="chart-bar-head">
            <span class="chart-bar-name">Показатель 1% Low — Редкие события (Без Pulse)</span>
            <span class="chart-bar-val">138 <span class="unit">FPS</span></span>
          </div>
          <div class="chart-bar-track">
            <div class="chart-bar-fill before" data-w="28%"></div>
          </div>
        </div>

        <div class="chart-bar-row">
          <div class="chart-bar-head">
            <span class="chart-bar-name">Показатель 1% Low — Стабильность (С примененным Pulse)</span>
            <span class="chart-bar-val" style="color:var(--accent)">200 <span class="unit" style="color:var(--accent)">FPS</span></span>
          </div>
          <div class="chart-bar-track">
            <div class="chart-bar-fill after" data-w="44%"></div>
          </div>
        </div>
      </div>

      <div class="results-text reveal">
        <div class="eyebrow">Замеры производительности</div>
        <h3>Реальное влияние на стабильность кадра</h3>
        <p>Игроки часто смотрят только на средний FPS, но комфорт игры определяют просадки в экшн-сценах (показатель 1% low). За счет отключения системных прерываний, DPC latency снижается со 150 до 45 микросекунд. Как результат — пропадают микрофризы и дергания при перестрелках.</p>
        <p style="margin-top:-8px;"><strong style="color:#fff;">450 FPS avg / 200 FPS 1% low — потолок результата</strong>, достижимый только при грамотной ручной настройке системы поверх Pulse (проверено автором лично). Из коробки прирост более умеренный и зависит от вашего железа и фона.</p>
        <div class="system-specs">
          Конфигурация тестового стенда: AMD Ryzen 5 5600 · GeForce GTX 1660 · 16 GB DDR4 RAM · Чистая Windows 10 (22H2).
        </div>
      </div>
    </div>
  </section>

  <!-- ============ VS TABLE SECTION ============ -->
  <section class="vs" id="vs">
    <div class="wrap">
      <div class="sec-head center">
        <div class="eyebrow">Сравнение решений</div>
        <h2>Отличия Pulse от стандартного софта</h2>
      </div>

      <div class="vs-container reveal">
        <table>
          <thead>
            <tr>
              <th>Функционал</th>
              <th class="col-target">Pulse</th>
              <th>Очистители диска</th>
              <th>Платные бустеры</th>
            </tr>
          </thead>
          <tbody>
            <tr>
              <td>Устранение DPC-задержек и HPET</td>
              <td class="col-target"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="var(--green)" stroke-width="3" style="vertical-align: middle; margin-right: 6px;"><polyline points="20 6 9 17 4 12"/></svg> Да</td>
              <td><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="var(--text-dark)" stroke-width="2.5" style="vertical-align: middle; margin-right: 6px;"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg> Нет</td>
              <td><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="var(--amber)" stroke-width="2.5" style="vertical-align: middle; margin-right: 6px;"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg> Частично</td>
            </tr>
            <tr>
              <td>Принудительная остановка фоновых задач</td>
              <td class="col-target"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="var(--green)" stroke-width="3" style="vertical-align: middle; margin-right: 6px;"><polyline points="20 6 9 17 4 12"/></svg> Да</td>
              <td><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="var(--text-dark)" stroke-width="2.5" style="vertical-align: middle; margin-right: 6px;"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg> Нет</td>
              <td><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="var(--green)" stroke-width="3" style="vertical-align: middle; margin-right: 6px;"><polyline points="20 6 9 17 4 12"/></svg> Да</td>
