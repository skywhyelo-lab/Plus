                <div class="proc-summary-bar">
                  <span>Доступно для высвобождения: <strong id="procTotalTerminable">0 МБ</strong></span>
                  <span style="color:var(--text-dark)" id="procFreedStatus">Всего закрыто: 0 МБ</span>
                </div>
              </div>

              <!-- PANEL: EXCEPTIONS -->
              <div class="mock-panel" id="panel-excs">
                <div class="mock-section-title">Белый список (Исключения)</div>
                <div class="mock-section-desc">Процессы из этого списка никогда не будут остановлены оптимизатором</div>

                <div class="exc-add-form">
                  <input type="text" id="excInput" placeholder="Имя процесса (например, streamlabs.exe)">
                  <button id="excAddBtn">Добавить</button>
