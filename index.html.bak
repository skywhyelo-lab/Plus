                  <div class="exc-column">
                    <div class="exc-header">Пользовательские <span class="count" id="userExcCount">0</span></div>
                    <div class="exc-list" id="userExcList">
                      <!-- Пользовательские исключения -->
                    </div>
                  </div>
                </div>
              </div>

              <!-- PANEL: OPTIMIZATION -->
              <div class="mock-panel" id="panel-opti">
                <div class="mock-section-title">Твики операционной системы</div>
